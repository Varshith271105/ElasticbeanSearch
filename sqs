{
  "Version": "2012-10-17",
  "Id": "default_policy",
  "Statement": [
    {
      "Sid": "OwnerFullAccess",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::352917280532:root"
      },
      "Action": "SQS:*",
      "Resource": "arn:aws:sqs:us-east-1:352917280532:s3-sns-sqs-kmit"
    },
    {
      "Sid": "Allow-SNS-SendMessage",
      "Effect": "Allow",
      "Principal": {
        "Service": "sns.amazonaws.com"
      },
      "Action": "SQS:SendMessage",
      "Resource": "arn:aws:sqs:us-east-1:352917280532:s3-sns-sqs-kmit",
      "Condition": {
        "ArnEquals": {
          "aws:SourceArn": "arn:aws:sns:us-east-1:352917280532:s3-sns-sqs-kmit"
        }
      }
    }
  ]
}
